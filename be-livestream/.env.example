# Application
APP_NAME=Livestream
NODE_ENV=development
PORT=3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=123123

# PostgreSQL
POSTGRES_DB=Backend_HGM
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Root admin bootstrap
ROOT_ADMIN_USERNAME=root_admin
ROOT_ADMIN_EMAIL=root@example.com
ROOT_ADMIN_PASSWORD=ChangeMe123!

# Encoder
ENCODER_PRIMARY_URL=http://localhost:8081
ENCODER_BACKUP_URL=http://localhost:8082
ENCODER_HEALTH_INTERVAL_MS=3000
ENCODER_HEALTH_TIMEOUT_MS=10000
ENCODER_FAILOVER_THRESHOLD=3

# Media
MEDIA_MAX_FILE_SIZE=10737418240
