NODE_ENV=development
ENGINE_DB_POLL_MS=2000
ENGINE_FFMPEG_BIN=ffmpeg

ENGINE_PREFETCH_ENABLED=true
ENGINE_PREFETCH_LOG_SKIPS=false
ENGINE_CACHE_DIR=/tmp/encoder-cache
ENGINE_OWNER_LEASE_MS=5000
ENGINE_ADVANCE_GRACE_MS=1500

# Webhook đăng ký VPS lên BE (phải trùng secret BE)
BACKEND_ENCODER_VPS_REGISTER_URL=http://host.docker.internal:3000/api/webhooks/encoder-vps/register
BACKEND_ENCODER_VPS_REGISTER_SECRET=change-me-long-random
BACKEND_ENCODER_VPS_HEARTBEAT_MS=15000

POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5433
POSTGRES_DB=Backend_HGM
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

MEDIA_MOUNT_PATH=../be-livestream/media
