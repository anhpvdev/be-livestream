NODE_ENV=development
ENGINE_DB_POLL_MS=2000
ENGINE_FFMPEG_BIN=ffmpeg

ENGINE_PREFETCH_ENABLED=true
ENGINE_PREFETCH_LOG_SKIPS=false
ENGINE_CACHE_DIR=/tmp/encoder-cache
ENGINE_OWNER_LEASE_MS=5000
ENGINE_OUTPUT_FPS=30
ENGINE_OUTPUT_GOP_SEC=2
# Nên giữ VIDEO = MAXRATE; BUFSIZE ~ 2× ví dụ 13600; code thêm minrate = VIDEO + x264 nal-hrd=cbr để ổn định ingest YouTube.
ENGINE_OUTPUT_VIDEO_BITRATE_KBPS=6800
ENGINE_OUTPUT_MAXRATE_KBPS=6800
ENGINE_OUTPUT_BUFSIZE_KBPS=13600
ENGINE_OUTPUT_AUDIO_BITRATE_KBPS=128

# UUID encoder_vps (cùng BE). Khi set: chỉ poll job livestream gán VPS này làm primary hoặc backup.
# Có thể để trống nếu bật webhook bên dưới — BE trả `id` và engine tự gắn sau khi đăng ký thành công.
#ENCODER_VPS_ID=

# Webhook đăng ký VPS lên BE (phải trùng secret BE)
BACKEND_ENCODER_VPS_REGISTER_URL=http://host.docker.internal:3000/api/webhooks/encoder-vps/register
BACKEND_ENCODER_VPS_REGISTER_SECRET=change-me-long-random
BACKEND_ENCODER_VPS_HEARTBEAT_MS=15000

POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5433
POSTGRES_DB=Backend_HGM
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

MEDIA_MOUNT_PATH=../be-livestream/media
